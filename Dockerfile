# ---- Стадия 1: Сборка приложения ----
FROM node:24-alpine AS build

# Рабочая директория внутри контейнера
WORKDIR /app

# Копируем файлы с зависимостями (для кэширования слоя npm install)
COPY package*.json ./

# Устанавливаем зависимости (npm ci — быстрее и чище для CI)
RUN npm ci

# Копируем остальные исходники (кроме тех, что в .dockerignore)
COPY . .

# Собираем приложение (продакшн-версия)
RUN npm run build --prod

# ---- Стадия 2: Раздача статики через nginx ----
FROM nginx:alpine

# Копируем результат сборки из предыдущей стадии в папку, откуда nginx отдаёт файлы
COPY --from=build /app/dist/test-dashboards/browser/. /usr/share/nginx/html/

# Указываем порт, который будет слушать контейнер (nginx по умолчанию слушает 80, но мы хотим 8080)
# Для этого нужно поправить конфиг nginx или просто экспортировать порт
# Проще всего: пробросить порт при запуске, но если хочешь, чтобы образ сразу слушал 8080,
# можно заменить конфиг. Пока оставим как есть, а при запуске укажем маппинг портов.
EXPOSE 80
